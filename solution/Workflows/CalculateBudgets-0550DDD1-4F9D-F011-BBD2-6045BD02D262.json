            "operationMetadataId": "9913ee5d-d97f-4c56-833c-b2e99c067cbc"
          }
        },
        "Recurrence_Table": {
          "type": "Compose",
          "inputs": [
            {
              "recurrenceValue": 0,
              "functionInterval": "Day",
              "intervalMultiplier": 1
            },
            {
              "recurrenceValue": 1,
              "functionInterval": "Day",
              "intervalMultiplier": 7
            },
            {
              "recurrenceValue": 2,
              "functionInterval": "Day",
              "intervalMultiplier": 14
            },
            {
              "recurrenceValue": 3,
              "functionInterval": "Month",
              "intervalMultiplier": 1
            },
            {
              "recurrenceValue": 4,
              "functionInterval": "Month",
              "intervalMultiplier": 1
            },
            {
              "recurrenceValue": 5,
              "functionInterval": "Month",
              "intervalMultiplier": 2
            },
            {
              "recurrenceValue": 6,
              "functionInterval": "Month",
              "intervalMultiplier": 3
            },
            {
              "recurrenceValue": 7,
              "functionInterval": "Month",
              "intervalMultiplier": 6
            },
            {
