        "For_each_budget": {
          "type": "Foreach",
          "foreach": "@outputs('Get_budgets_with_an_infinite_recurrence')?['body/value']",
          "actions": {
            "Get_max_date_entry": {
              "type": "OpenApiConnection",
              "inputs": {
                "parameters": {
                  "entityName": "mda_budgetentries",
                  "fetchXml": "<fetch top=\"1\">\n  <entity name=\"mda_budgetentry\">\n    <attribute name=\"mda_date\"/>\n    <filter>\n      <condition attribute=\"mda_budget\" operator=\"eq\" value=\"@{item()?['mda_budgetid']}\" />\n    </filter>\n   <order attribute=\"mda_date\" descending=\"true\"/>\n  </entity>\n</fetch>",
                  "x-ms-odata-metadata-full": false
                },
                "host": {
                  "apiId": "/providers/Microsoft.PowerApps/apis/shared_commondataserviceforapps",
                  "operationId": "ListRecords",
                  "connectionName": "shared_commondataserviceforapps-1"
                }
              },
              "metadata": {
                "operationMetadataId": "f4f9b68b-706d-49f5-8e91-ee3e036a279d"
              }
            },
            "Max_date_is_5_years_from_today": {
              "type": "If",
              "expression": {
                "and": [
                  {
                    "greater": [
                      "@coalesce(first(outputs('Get_max_date_entry')?['body/value'])?['mda_date'],item()?['mda_date'])",
                      "@formatDateTime(addToTime(utcNow(), 5, 'Year'), 'yyyy-MM-ddT00:00:00Z')"
                    ]
                  }
                ]
              },
              "actions": {},
              "else": {
                "actions": {
                  "Set_Batch_Patch_Body": {
                    "type": "SetVariable",
                    "inputs": {
                      "name": "Batch Patch Body",
                      "value": "POST [Organization Uri]/api/data/v9.2/$batch HTTP/1.1\nOData-MaxVersion: 4.0\nOData-Version: 4.0\nIf-None-Match: null\nAccept: application/json\nContent-Type: multipart/mixed; boundary=\"batch_body\"\n\n--batch_body\nContent-Type: multipart/mixed; boundary=\"changeset_body\""
                    },
                    "metadata": {
                      "operationMetadataId": "8c0453cc-348e-47db-b483-ac601ffff350"
                    }
                  },
                  "End_Batch_Patch_Body": {
                    "type": "AppendToStringVariable",
                    "inputs": {
                      "name": "Batch Patch Body",
                      "value": "\n\n--changeset_body--\n\n\n--batch_body--\n\n\n\n"
                    },
                    "runAfter": {
                      "Create_occurrences_until": [
                        "Succeeded"
                      ]
                    },
                    "metadata": {
                      "operationMetadataId": "9e2930a3-ec0d-4ca2-aff1-d368a31c07ee"
                    }
                  },
                  "DEBUG_BATCH_OBJECT": {
                    "type": "Compose",
                    "inputs": "@variables('Batch Patch Body')",
                    "runAfter": {
                      "End_Batch_Patch_Body": [
                        "Succeeded"
                      ]
                    },
                    "metadata": {
                      "operationMetadataId": "eceea324-3e08-401b-9ba0-cec5c9b4c6ce"
                    }
                  },
                  "Lookup_recurrence_table": {
                    "type": "Query",
                    "inputs": {
                      "from": "@outputs('Recurrence_Table')",
                      "where": "@equals(item()?['recurrenceValue'],items('For_each_budget')?['mda_recurrence'])"
                    },
                    "runAfter": {
                      "Set_Batch_Patch_Body": [
                        "Succeeded"
                      ]
                    },
                    "metadata": {
                      "operationMetadataId": "32bba65b-dc0a-4bc0-a0a7-cad0a5f476d5"
                    }
                  },
                  "Create_occurrences_until": {
                    "type": "Until",
                    "expression": "@greaterOrEquals(variables('Incremental Date'),formatDateTime(addToTime(utcNow(), 5, 'Year'), 'yyyy-MM-ddT00:00:00Z'))",
                    "limit": {
                      "count": 5000,
                      "timeout": "PT1H"
                    },
                    "actions": {
                      "Set_Incremental_Date": {
                        "type": "SetVariable",
                        "inputs": {
                          "name": "Incremental Date",
                          "value": "@coalesce(\r\n  outputs('Increment_semi-monthly_date_by_whole_month'),\r\n  outputs('Increment_semi-monthly_date_by_month_less_15_days'),\r\n  outputs('Increment_non-semi-monthly_date')\r\n)"
                        },
                        "runAfter": {
                          "Recurrence_is_semi-monthly": [
                            "Succeeded"
                          ]
                        },
                        "metadata": {
                          "operationMetadataId": "3551394a-6b2b-4522-8d84-26ad66020b42"
                        }
                      },
                      "Append_to_Batch_Patch_Body": {
                        "type": "AppendToStringVariable",
                        "inputs": {
                          "name": "Batch Patch Body",
                          "value": "\n\n--changeset_body\nContent-Type: application/http\nContent-Transfer-Encoding: binary\nContent-ID: @{guid()}\n\nPOST /api/data/v9.2/mda_budgetentries HTTP/1.1\nContent-Type: application/json; type=entry\n\n{\n  \"mda_date\": \"@{formatDateTime(variables('Incremental Date'),'yyyy-MM-dd')}\",\n  \"mda_Budget@odata.bind\": \"/mda_budgets(@{item()?['mda_budgetid']})\"\n}"
                        },
                        "runAfter": {
                          "Set_Incremental_Date": [
                            "Succeeded"
                          ]
                        },
                        "metadata": {
                          "operationMetadataId": "76e46131-b506-4d72-ab68-65eaeb538252"
                        }
                      },
                      "Recurrence_is_semi-monthly": {
                        "type": "If",
                        "expression": {
                          "and": [
                            {
                              "equals": [
                                "@items('For_each_budget')?['mda_recurrence']",
                                3
                              ]
                            }
                          ]
                        },
                        "actions": {
                          "Counter_not_yet_set": {
                            "type": "If",
                            "expression": {
                              "and": [
                                {
                                  "equals": [
                                    "@variables('Counter')",
                                    -1
                                  ]
                                }
                              ]
                            },
                            "actions": {
                              "Get_count_of_semi-monthly_occurrences": {
                                "type": "OpenApiConnection",
                                "inputs": {
                                  "parameters": {
                                    "entityName": "mda_budgetentries",
                                    "fetchXml": "<fetch aggregate=\"true\">\n  <entity name=\"mda_budgetentry\">\n<filter>\n      <condition attribute=\"mda_budget\" operator=\"eq\" value=\"@{item()?['mda_budgetid']}\" />\n    </filter>\n    <attribute name=\"mda_budgetentryid\" alias=\"count\"\n      aggregate=\"count\"/>\n  </entity>\n</fetch>",
                                    "x-ms-odata-metadata-full": false
                                  },
                                  "host": {
                                    "apiId": "/providers/Microsoft.PowerApps/apis/shared_commondataserviceforapps",
                                    "operationId": "ListRecords",
                                    "connectionName": "shared_commondataserviceforapps-1"
                                  }
                                }
                              },
                              "Set_Counter": {
                                "type": "SetVariable",
                                "inputs": {
                                  "name": "Counter",
                                  "value": "@first(outputs('Get_count_of_semi-monthly_occurrences')?['body/value'])?['count']"
                                },
                                "runAfter": {
                                  "Get_count_of_semi-monthly_occurrences": [
                                    "Succeeded"
                                  ]
                                }
                              }
                            },
                            "else": {
                              "actions": {
                                "Increment_Counter": {
                                  "type": "IncrementVariable",
                                  "inputs": {
                                    "name": "Counter",
                                    "value": 1
                                  }
                                }
                              }
                            }
                          },
                          "Counter_is_even": {
                            "type": "If",
                            "expression": {
                              "and": [
                                {
                                  "equals": [
                                    "@mod(variables('Counter'),2)",
                                    0
                                  ]
                                }
                              ]
                            },
                            "actions": {
                              "Increment_semi-monthly_date_by_whole_month": {
                                "type": "Compose",
                                "inputs": "@addToTime(\r\n  item()?['mda_date'],\r\n  div(variables('Counter'),2),\r\n  'Month',\r\n  'yyyy-MM-ddT00:00:00Z'\r\n)\r\n",
                                "metadata": {
                                  "operationMetadataId": "1d6e39ca-467e-430b-a520-8ae1e33568e2"
                                }
                              }
                            },
                            "else": {
                              "actions": {
                                "Increment_semi-monthly_date_by_month_less_15_days": {
                                  "type": "Compose",
                                  "inputs": "@addToTime(\r\n  subtractFromTime(\r\n    item()?['mda_date'],\r\n    15,\r\n    'Day'),\r\n  add(int(div(variables('Counter'),2)),1),\r\n  'Month',\r\n  'yyyy-MM-ddT00:00:00Z'\r\n)",
                                  "metadata": {
                                    "operationMetadataId": "1d6e39ca-467e-430b-a520-8ae1e33568e2"
                                  }
                                }
                              }
                            },
                            "runAfter": {
                              "Counter_not_yet_set": [
                                "Succeeded"
                              ]
                            }
                          }
                        },
                        "else": {
                          "actions": {
                            "Increment_non-semi-monthly_date": {
                              "type": "Compose",
                              "inputs": "@addToTime(\r\n  if(\r\n    equals(variables('Incremental Date'),''),\r\n    coalesce(\r\n      first(outputs('Get_max_date_entry')?['body/value'])?['mda_date'],\r\n      item()?['mda_date']\r\n    ),\r\n    variables('Incremental Date'))\r\n  ,\r\n  if(\r\n    and(\r\n      empty(outputs('Get_max_date_entry')?['body/value']),\r\n      equals(variables('Incremental Date'),'')\r\n      ),\r\n    0,\r\n    First(body('Lookup_recurrence_table'))?['intervalMultiplier']\r\n  ),\r\n  First(body('Lookup_recurrence_table'))?['functionInterval'],\r\n  'yyyy-MM-ddT00:00:00Z'\r\n)\r\n",
                              "metadata": {
                                "operationMetadataId": "1d6e39ca-467e-430b-a520-8ae1e33568e2"
                              }
                            }
                          }
                        }
                      }
                    },
                    "runAfter": {
                      "Lookup_recurrence_table": [
                        "Succeeded"
                      ]
                    }
                  },
                  "Batch_Patch": {
                    "type": "OpenApiConnection",
                    "inputs": {
                      "parameters": {
                        "request/method": "POST",
                        "request/url": "/api/data/v9.2/$batch",
                        "request/headers": {
                          "OData-MaxVersion": "4.0",
                          "OData-Version": "4.0",
                          "If-None-Match": "@{string('null')}",
                          "Accept": "application/json",
                          "Content-Type": "multipart/mixed;boundary=@{string('\"batch_body\"')}"
                        },
                        "request/body": "@variables('Batch Patch Body')"
                      },
                      "host": {
                        "apiId": "/providers/Microsoft.PowerApps/apis/shared_webcontents",
                        "operationId": "InvokeHttp",
                        "connectionName": "shared_webcontents"
                      }
                    },
                    "runAfter": {
                      "DEBUG_BATCH_OBJECT": [
                        "Succeeded"
                      ]
                    }
                  }
                }
              },
              "runAfter": {
                "Get_max_date_entry": [
                  "Succeeded"
                ]
              },
              "metadata": {
                "operationMetadataId": "e7b1fa26-1256-493a-926c-a43792199be3"
              }
            }
          },
          "runAfter": {
            "Get_budgets_with_an_infinite_recurrence": [
              "Succeeded"
            ]
          },
          "runtimeConfiguration": {
            "concurrency": {
              "repetitions": 50
            }
          },
          "metadata": {
            "operationMetadataId": "04b1cae5-5dd6-412b-979c-8e31ec592a0a"
