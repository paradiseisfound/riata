        "Get_Categories": {
          "type": "OpenApiConnection",
          "inputs": {
            "parameters": {
              "entityName": "mda_transactioncategories",
              "fetchXml": "<fetch>\n  <entity name=\"mda_transactioncategory\">\n    <attribute name=\"mda_name\" />\n    <attribute name=\"mda_transactioncategoryid\" />\n    <attribute name=\"mda_type\" />\n    <attribute name=\"mda_depth\" />\n    <attribute name=\"mda_index\" />\n    <attribute name=\"mda_color\" />\n    <link-entity name=\"mda_profile\"\n      from=\"mda_profileid\"\n      to=\"mda_profile\"\n      link-type=\"inner\"\n      alias=\"profile\">\n      <filter>\n      <condition attribute=\"mda_profileid\" operator=\"eq\"\n        value=\"@{triggerBody()?['text']}\" />\n    </filter>\n    </link-entity>\n    <order attribute=\"mda_index\" />\n  </entity>\n</fetch>",
              "x-ms-odata-metadata-full": false
            },
            "host": {
              "apiId": "/providers/Microsoft.PowerApps/apis/shared_commondataserviceforapps",
              "operationId": "ListRecords",
              "connectionName": "shared_commondataserviceforapps-1"
            }
          },
