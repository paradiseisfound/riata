          "foreach": "@outputs('Get_Categories')?['body/value']",
          "actions": {
            "Get_sums": {
              "type": "Scope",
              "actions": {
                "Sum_of_transaction_splits": {
                  "type": "OpenApiConnection",
                  "inputs": {
                    "parameters": {
                      "entityName": "mda_transactionsplits",
                      "fetchXml": "<fetch aggregate=\"true\">\n  <entity name=\"mda_transactionsplit\">\n    <attribute name=\"mda_amount\" alias=\"amount\" aggregate=\"sum\" />\n    <filter type=\"and\">\n      <condition attribute=\"mda_category\" operator=\"eq\" value=\"@{item()?['mda_transactioncategoryid']}\" />\n    </filter>\n    <link-entity name=\"mda_transaction\"\n      from=\"mda_transactionid\"\n      to=\"mda_transaction\"\n      link-type=\"inner\"\n      alias=\"transaction\">\n      <filter type=\"and\">\n        <condition attribute=\"mda_date\" operator=\"between\">\n          <value>@{triggerBody()?['date']}</value>\n          <value>@{triggerBody()?['date_1']}</value>\n        </condition>\n      </filter>\n    </link-entity>\n  </entity>\n</fetch>",
                      "x-ms-odata-metadata-full": false
                    },
                    "host": {
                      "apiId": "/providers/Microsoft.PowerApps/apis/shared_commondataserviceforapps",
                      "operationId": "ListRecords",
                      "connectionName": "shared_commondataserviceforapps-1"
                    }
                  }
                },
                "Sum_of_transactions": {
                  "type": "OpenApiConnection",
                  "inputs": {
                    "parameters": {
                      "entityName": "mda_transactions",
                      "fetchXml": "<fetch aggregate=\"true\">\n  <entity name=\"mda_transaction\">\n    <attribute name=\"mda_amount\" alias=\"amount\" aggregate=\"sum\" />\n    <filter type=\"and\">\n      <condition attribute=\"mda_category\" operator=\"eq\"\n        value=\"@{item()?['mda_transactioncategoryid']}\" />\n      <condition attribute=\"mda_date\" operator=\"between\">\n        <value>@{triggerBody()?['date']}</value>\n        <value>@{triggerBody()?['date_1']}</value>\n      </condition>\n    </filter>\n    <link-entity name=\"mda_transactionsplit\"\n      from=\"mda_transaction\"\n      to=\"mda_transactionid\"\n      link-type=\"outer\"\n      alias=\"splits\">\n    </link-entity>\n  </entity>\n</fetch>",
                      "x-ms-odata-metadata-full": false
                    },
                    "host": {
                      "apiId": "/providers/Microsoft.PowerApps/apis/shared_commondataserviceforapps",
                      "operationId": "ListRecords",
                      "connectionName": "shared_commondataserviceforapps-1"
                    }
                  }
                },
                "Sum_of_budgets": {
                  "type": "OpenApiConnection",
                  "inputs": {
                    "parameters": {
                      "entityName": "mda_budgetentries",
                      "fetchXml": "<fetch aggregate=\"true\">\n  <entity name=\"mda_budgetentry\">\n    <attribute name=\"mda_amount\" alias=\"amount\" aggregate=\"sum\" />\n    <filter type=\"and\">\n      <condition attribute=\"mda_date\" operator=\"between\">\n        <value>@{triggerBody()?['date']}</value>\n        <value>@{triggerBody()?['date_1']}</value>\n      </condition>\n    </filter>\n    <link-entity name=\"mda_budget\"\n      from=\"mda_budgetid\"\n      to=\"mda_budget\"\n      link-type=\"inner\"\n      alias=\"budget\">\n      <filter type=\"and\">\n        <condition attribute=\"mda_category\" operator=\"eq\"\n          value=\"@{item()?['mda_transactioncategoryid']}\" />\n      </filter>\n    </link-entity>\n  </entity>\n</fetch>",
                      "x-ms-odata-metadata-full": false
                    },
                    "host": {
                      "apiId": "/providers/Microsoft.PowerApps/apis/shared_commondataserviceforapps",
                      "operationId": "ListRecords",
                      "connectionName": "shared_commondataserviceforapps-1"
                    }
                  }
                }
              }
            },
            "Append_to_array_variable": {
              "type": "AppendToArrayVariable",
              "inputs": {
                "name": "Array",
                "value": "@json(\r\n  concat(\r\n    substring(\r\n      string(item()),\r\n      0,\r\n      sub(length(string(item())),1)\r\n    ),\r\n    ',\"budgetAmount\": ',\r\n    coalesce(\r\n      first(outputs('Sum_of_budgets')?['body/value'])?['amount'],0\r\n    ),\r\n    ',\"transactionAmount\": ',\r\n    mul(add(\r\n      coalesce(\r\n        first(outputs('Sum_of_transaction_splits')?['body/value'])?['amount'],\r\n        0\r\n      ),\r\n      coalesce(\r\n        first(outputs('Sum_of_transactions')?['body/value'])?['amount'],\r\n        0\r\n      )\r\n    ),-1),\r\n    '}'\r\n  )\r\n)"
              },
              "runAfter": {
                "Get_sums": [
                  "Succeeded"
                ]
              }
            }
