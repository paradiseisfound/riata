          "inputs": {
            "parameters": {
              "entityName": "mda_budgetentries",
              "fetchXml": "<fetch version=\"1.0\" output-format=\"xml-platform\" mapping=\"logical\" distinct=\"false\">\n  <entity name=\"mda_budgetentry\">\n    <attribute name=\"mda_amount\" />\n    <attribute name=\"mda_date\" />\n    <attribute name=\"mda_name\" />\n    <attribute name=\"mda_categoryname\" />\n    <order attribute=\"mda_date\" descending=\"true\" />\n    <link-entity name=\"mda_budget\"\n      from=\"mda_budgetid\"\n      to=\"mda_budget\"\n      link-type=\"inner\"\n      alias=\"budget\">\n      <link-entity name=\"mda_profile\"\n        from=\"mda_profileid\"\n        to=\"mda_profile\"\n        link-type=\"inner\"\n        alias=\"profile\">\n        <filter type=\"and\">\n          <condition attribute=\"mda_profileid\" operator=\"eq\" value=\"@{triggerBody()?['text_3']}\" />\n        </filter>\n      </link-entity>\n    </link-entity>\n    <filter type=\"and\">\n      @{triggerBody()?['text']}\n    </filter>\n  </entity>\n</fetch>",
              "x-ms-odata-metadata-full": false
            },
            "host": {
              "apiId": "/providers/Microsoft.PowerApps/apis/shared_commondataserviceforapps",
              "operationId": "ListRecords",
              "connectionName": "shared_commondataserviceforapps-1"
            }
          },
          "runAfter": {},
          "metadata": {
            "operationMetadataId": "55f96cf2-9754-4537-a0a5-415b93ec9916"
          }
        },
