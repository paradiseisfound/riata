              "Amount": "@item()?['mda_amount']",
              "Budget": "@item()?['mda_name']",
              "Category": "@item()?['mda_categoryname']"
            }
          },
          "runAfter": {
            "Fetch_Budget_Entries": [
              "Succeeded"
            ]
          },
          "metadata": {
            "operationMetadataId": "25538fb7-3f04-403f-9341-e155d8633919"
          }
        },
